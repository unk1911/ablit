#!/usr/bin/env bash
set -euo pipefail

LLAMA_BIN="$HOME/ablit/llama.cpp/build-cuda/bin/llama-cli"
MODEL="$HOME/ablit/ablit_models/01_gemma4_e4b_heretic_q4_k_m/gemma-4-E4B-it-heretic-Q4_K_M.gguf"

if [[ ! -x "$LLAMA_BIN" ]]; then
  echo "Missing llama-cli at: $LLAMA_BIN"
  exit 1
fi

if [[ ! -f "$MODEL" ]]; then
  echo "Missing model file: $MODEL"
  exit 1
fi

ARGS=(
  -m "$MODEL"
  -ngl auto
  -c 2048
  -n 256
  --simple-io
  --reasoning off
)

# If args carry a prompt/file (-p/-f/--prompt/--file), run single-turn and tee to full.log; else interactive.
ONESHOT=0
for arg in "$@"; do
  case "$arg" in
    -p|-f|--prompt|--file|--prompt=*|--file=*) ONESHOT=1; break ;;
  esac
done

if (( ONESHOT )); then
  "$LLAMA_BIN" "${ARGS[@]}" -st --log-disable "$@" 2>&1 | tee full.log
else
  exec "$LLAMA_BIN" "${ARGS[@]}" "$@"
fi
