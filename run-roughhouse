#!/usr/bin/env bash
set -euo pipefail

LLAMA_BIN="$HOME/ablit/llama.cpp/build-cuda/bin/llama-cli"
MODEL="$HOME/ablit/ablit_models/06_qwen40b_roughhouse_iq4xs/Qwen3.5-40B-RoughHouse-Claude-4.6-Opus-Polar-Deckard-Uncensored-Heretic-Thinking.IQ4_XS.gguf"

if [[ ! -x "$LLAMA_BIN" ]]; then
  echo "Missing llama-cli at: $LLAMA_BIN"
  exit 1
fi

if [[ ! -f "$MODEL" ]]; then
  echo "Missing model file: $MODEL"
  echo "Download with: ./setup.sh --model qwen40b-roughhouse-iq4xs"
  exit 1
fi

ARGS=(
  -m "$MODEL"
  -ngl 99
  -c 4096
  -n 2024
  --simple-io
  --temp 0.7
  --repeat-penalty 1.05
  -sys "Be vivid and precise."
)

# If args carry a prompt/file (-p/-f/--prompt/--file), run single-turn and tee to full.log; else interactive.
ONESHOT=0
for arg in "$@"; do
  case "$arg" in
    -p|-f|--prompt|--file|--prompt=*|--file=*) ONESHOT=1; break ;;
  esac
done

if (( ONESHOT )); then
  "$LLAMA_BIN" "${ARGS[@]}" -st --log-disable "$@" 2>&1 | tee full.log
else
  exec "$LLAMA_BIN" "${ARGS[@]}" "$@"
fi
